  "while-defined": {
    "prefix": ["while-defined", "whiled"],
    "description": "while the variable [d]efined run the specified set of commands",
    "body": [
      "while set ${1|-q,--query|} \"${2:variable}\"",
      "\t${3:command ...}",
      "end"
    ]
  },
  "while-not-defined": {
    "prefix": ["while-not-defined", "whilend"],
    "description": "while the variable [n]ot [d]efined run the specified set of commands",
    "body": [
      "while not set ${1|-q,--query|} \"${2:variable}\"",
      "\t${3:command ...}",
      "end"
    ]
  },
  "for": {
    "prefix": "for",
    "description": "run the specified commands iterating thought items",
    "body": ["for ${1:item} in ${2:expression}", "\t${3:command ...}", "end"]
  },
  "for-range": {
    "prefix": ["for-range", "forr"],
    "description": "run the specified set of commands iterating over the number [r]ange",
    "body": [
      "for ${1:item} in $(seq ${2:from} ${3:to})",
      "\t${4:command ...}",
      "end"
    ]
  },
  "for-stepped-range": {
    "prefix": ["for-stepped-range", "forsr"],
    "description": "run the specified set of commands iterating over the [s]tepped number [r]ange",
    "body": [
      "for ${1:item} in $(seq ${2:from} ${3:step} ${4:to})",
      "\t${5:command ...}",
      "end"
    ]
  },
  "for-files": {
    "prefix": ["for-files", "forf"],
    "description": "run the specified set of commands iterating over [f]iles",
    "body": ["for ${1:item} in *.${2:extension}", "\t${3:command ...}", "end"]
  },
  "switch": {
    "prefix": "switch2",
    "description": "find the first matching pattern out of 2 available (including the default fallback) and run the specified commands corresponding to it",
    "body": [
      "switch \"${1:expression}\"",
      "\tcase ${2:pattern}",
      "\t\t${3:command ...}",
      "\tcase '*'",
      "\t\t${4:command ...}",
      "end"
    ]
  },
  "switch3": {
    "prefix": "switch3",
    "description": "find the first matching pattern out of 3 available (including the default fallback) and run the specified commands corresponding to it",
    "body": [
      "switch \"${1:expression}\"",
      "\tcase ${2:pattern}",
      "\t\t${3:command ...}",
      "\tcase ${4:pattern}",
      "\t\t${5:command ...}",
      "\tcase '*'",
      "\t\t${6:command ...}",
      "end"
    ]
  },
  "switch4": {
    "prefix": "switch4",
    "description": "find the first matching pattern out of 4 available (including the default fallback) and run the specified commands corresponding to it",
    "body": [
      "switch \"${1:expression}\"",
      "\tcase ${2:pattern}",
      "\t\t${3:command ...}",
      "\tcase ${4:pattern}",
      "\t\t${5:command ...}",
      "\tcase ${6:pattern}",
      "\t\t${7:command ...}",
      "\tcase '*'",
      "\t\t${8:command ...}",
      "end"
    ]
  },
  "switch5": {
    "prefix": "switch5",
    "description": "find the first matching pattern out of 5 available (including the default fallback) and run the specified commands corresponding to it",
    "body": [
