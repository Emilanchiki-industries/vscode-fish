      "\t\t${5:command ...}",
      "\tcase ${6:pattern}",
      "\t\t${7:command ...}",
      "\tcase ${8:pattern}",
      "\t\t${9:command ...}",
      "\tcase '*'",
      "\t\t${10:command ...}",
      "end"
    ]
  },
  "switch6": {
    "prefix": "switch6",
    "description": "find the first matching pattern out of 6 available (including the default fallback) and run the specified commands corresponding to it",
    "body": [
      "switch \"${1:expression}\"",
      "\tcase ${2:pattern}",
      "\t\t${3:command ...}",
      "\tcase ${4:pattern}",
      "\t\t${5:command ...}",
      "\tcase ${6:pattern}",
      "\t\t${7:command ...}",
      "\tcase ${8:pattern}",
      "\t\t${9:command ...}",
      "\tcase ${10:pattern}",
      "\t\t${11:command ...}",
      "\tcase '*'",
      "\t\t${12:command ...}",
      "end"
    ]
  },
  "function": {
    "prefix": ["function", "fu"],
    "description": "define the [fu]nction",
    "body": [
      "function ${1:name}",
      "\t${2:command ...}",
      "end"
    ]
  },
  "function-described": {
    "prefix": ["function-described", "fd"],
    "description": "define the [f]unction with the specified [d]escription",
    "body": [
      "function ${1:name} ${2|-d,--description|} ${3:explanation}",
      "\t${4:command ...}",
      "end"
    ]
  },
  "function-with-arguments": {
    "prefix": ["function-with-arguments", "fa"],
    "description": "define the [f]unction with the specified [a]rguments",
    "body": [
      "function ${1:name} ${2|-a,--argument-names|} ${3:argument ...}",
      "\t${4:command ...}",
      "end"
    ]
  },
  "function-described-with-arguments": {
    "prefix": ["function-described-with-arguments", "fda"],
    "description": "define the [f]unction with the specified [d]escription and [a]rguments",
    "body": [
      "function ${1:name} ${2|-d,--description|} ${3:explanation} ${4|-a,--argument-names|} ${5:argument ...}",
      "\t${6:command ...}",
      "end"
    ]
  },
  "begin": {
    "prefix": ["begin", "be"],
    "description": "group commands",
    "body": ["begin", "\t${1:command ...}", "end"]
  },
  "begin-redirected": {
    "prefix": ["begin-redirected", "ber"],
    "description": "group commands and redirect their output",
    "body": ["begin", "\t${1:command ...}", "end ${2|>,2>|} ${3:file}"]
  },
  "set": {
    "prefix": "set",
    "description": "define or set a variable with the specified value",
    "body": "set ${1:variable} ${2:value}"
  },
  "set-index": {
    "prefix": ["set-index", "seti"],
    "description": "define or set a variable value with the specified [i]ndex",
    "body": "set ${1:variable}[${2:index}] ${3:value}"
  },
  "set-append": {
    "prefix": ["set-append", "seta"],
    "description": "append the value to the specified variable",
    "body": "set ${1|-a,--append|} ${2:variable} ${3:value}"
  },
  "set-prepend": {
    "prefix": ["set-prepend", "setp"],
    "description": "prepend the value to the specified variable",
    "body": "set ${1|-p,--prepend|} ${2:variable} ${3:value}"
  },
  "string": {
    "prefix": "string",
    "description": "string builtin",
    "body": "string ${1|collect,escape,join,join0,length,lower,match,pad,repeat,replace,split,split0,sub,trim,unescape,upper|} -- ${2:argument ...}"
  },
  "string-match": {
    "prefix": "string-match",
    "description": "string filtering",
    "body": "string match -- '${1:pattern}' ${2:argument ...}"
  },
  "string-match-all": {
    "prefix": "string-match-all",
    "description": "string filtering ([a]ll)",
    "body": "string match ${1|-a,--all|} -- '${2:pattern}' ${3:argument ...}"
  },
  "string-not-match": {
    "prefix": "string-not-match",
    "description": "string filtering (in[v]ert)",
    "body": "string match ${1|-v,--invert|} -- '${2:pattern}' ${3:argument ...}"
  },
  "string-regex-match": {
    "prefix": "string-regex-match",
