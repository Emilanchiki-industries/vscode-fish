{
  "shebang": {
    "prefix": "shebang",
    "description": "shebang",
    "body": "#!/usr/bin/env fish"
  },
  "shebang-with-arguments": {
    "prefix": "shebang-with-arguments",
    "description": "shebang with arguments",
    "body": "#!/usr/bin/env ${1|-S,--split-string|} fish ${2|argument ...|}"
  },
  "and": {
    "prefix": "and",
    "description": "run the second command just if the first one succeded",
    "body": "${1:first-expression}${2|; and, &&|} ${3:second-expression}"
  },
  "or": {
    "prefix": "or",
    "description": "run the second command just if the first one failed",
    "body": "${1:first-expression}${2|; or, \\|\\||} ${3:second-expression}"
  },
  "if": {
    "prefix": "if",
    "description": "check if the condition is true and run the specified commands",
    "body": ["if ${1:condition}", "\t${2:command ...}", "end"]
  },
  "if-else": {
    "prefix": "if-else",
    "description": "check if the condition is true and run the first set of commands, and the second one otherwise",
    "body": [
      "if ${1:condition}",
      "\t${2:command ...}",
      "else",
      "\t${3:command ...}",
      "end"
    ]
  },
  "if-file-newer-than": {
    "prefix": ["if-file-newer-than", "ifnt"],
    "description": "check if the first file is newer, or the first file exists and the second doesn't, and if true run the specified set of commands",
    "body": [
      "if test \"${1:first-file}\" -nt \"${2:second-file}\"",
      "\t${3:command ...}",
      "end"
    ]
  },
  "if-file-older-than": {
    "prefix": ["if-file-older-than", "ifot"],
    "description": "check if the second file is newer, or the second file exists and the first doesn't, and if true run the specified set of commands",
    "body": [
      "if test \"${1:first-file}\" -ot \"${2:second-file}\"",
      "\t${3:command ...}",
      "end"
    ]
  },
  "if-file-equal-to": {
    "prefix": ["if-file-equal-to", "ifef"],
    "description": "check if two file references refer to the same one, and if true run the specified set of commands",
    "body": [
      "if test \"${1:first-file}\" -ef \"${2:second-file}\"",
      "\t${3:command ...}",
      "end"
    ]
  },
  "if-less-than": {
    "prefix": ["if-less-than", "iflt"],
    "description": "check if the first number is [l]ess [t]han the second one and if true run the specified set of commands",
    "body": [
      "if test \"${1:first-number}\" -lt \"${2:second-number}\"",
      "\t${3:command ...}",
      "end"
    ]
  },
  "if-greater-than": {
    "prefix": ["if-greater-than", "ifgt"],
    "description": "check if the first number is [g]reater [t]han the second one and if true run the specified set of commands",
    "body": [
      "if test \"${1:first-number}\" -gt \"${2:second-number}\"",
      "\t${3:command ...}",
      "end"
    ]
  },
  "if-less-or-equal": {
    "prefix": ["if-less-or-equal", "ifle"],
    "description": "check if the first number is [l]ess than or [e]qual to the second one and if true run the specified set of commands",
    "body": [
      "if test \"${1:first-number}\" -le \"${2:second-number}\"",
      "\t${3:command ...}",
      "end"
    ]
  },
  "if-greater-or-equal": {
    "prefix": ["if-greater-or-equal", "ifge"],
    "description": "check if the first number is [g]reater than or [e]qual to the second one and if true run the specified set of commands",
    "body": [
      "if test \"${1:first-number}\" -ge \"${2:second-number}\"",
      "\t${3:command ...}",
      "end"
    ]
  },
  "if-equal-to": {
    "prefix": ["if-equal-to", "ifeq"],
    "description": "check if the first number is [eq]ual to the second one and if true run the specified set of commands",
    "body": [
      "if test \"${1:first-number}\" -eq \"${2:second-number}\"",
      "\t${3:command ...}",
      "end"
    ]
  },
  "if-not-equal-to": {
    "prefix": ["if-not-equal-to", "ifne"],
    "description": "check if the first number is [n]ot [e]qual to the second one and if true run the specified set of commands",
    "body": [
      "if test \"${1:first-number}\" -ne \"${2:second-number}\"",
      "\t${3:command ...}",
      "end"
    ]
  },
  "if-string-equal-to": {
    "prefix": ["if-string-equal-to", "ifseq"],
    "description": "check if the first [s]tring is [eq]ual to the second one and if true run the specified set of commands",
    "body": [
      "if test \"${1:first-string}\" = \"${2:second-string}\"",
      "\t${3:command ...}",
      "end"
    ]
  },
  "if-string-not-equal-to": {
    "prefix": ["if-string-not-equal-to", "ifsne"],
    "description": "check if the first [s]tring is [n]ot [e]qual to the second one and if true run the specified set of commands",
    "body": [
      "if test \"${1:first-string}\" != \"${2:second-string}\"",
      "\t${3:command ...}",
      "end"
    ]
  },
  "if-string-empty": {
    "prefix": ["if-string-empty", "ifz"],
    "description": "check if the string has [z]ero characters inside it (empty) and if true run the specified set of commands",
    "body": [
      "if test -z \"${1:string}\"",
      "\t${2:command ...}",
      "end"
    ]
  },
  "if-string-not-empty": {
    "prefix": ["if-string-not-empty", "ifn"],
    "description": "check if the string is [n]ot empty and if true run the specified set of commands",
    "body": [
      "if test -n \"${1:string}\"",
      "\t${2:command ...}",
      "end"
    ]
  "if-string-not-empty": {
    "prefix": "if-string-not-empty",
    "description": "if with string comparison ([n]ot empty)",
    "body": ["if test -n \"${1:expression}\"", "\t${2:command ...}", "end"]
  },
  "if-defined": {
    "prefix": ["if-defined", "ifd"],
    "description": "check if the variable [d]efined and if true run the specified set of commands",
    "body": [
      "if set ${1|-q,--query|} \"${2:variable}\"",
      "\t${3:command ...}",
      "end"
    ]
  },
  "if-not-defined": {
    "prefix": ["if-not-defined", "ifnd"],
    "description": "check if the variable [n]ot [d]efined and if true run the specified set of commands",
    "body": [
      "if not set ${1|-q,--query|} \"${2:variable}\"",
      "\t${3:command ...}",
      "end"
    ]
  },
  "while": {
    "prefix": ["while", "w"],
    "description": "[w]hile the condition is true run the specified commands",
    "body": ["while ${1:condition}", "\t${2:command ...}", "end"]
  },
  "while-file-newer-than": {
